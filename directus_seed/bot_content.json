[
  {
    "key": "menu_trial_response",
    "value": "\u041f\u043e\u043f\u0440\u043e\u0431\u0443\u0439\u0442\u0435 \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u044b\u0439 \u043f\u0435\u0440\u0438\u043e\u0434 \u043d\u0430 7 \u0434\u043d\u0435\u0439. \u041e\u043d \u0434\u043e\u0441\u0442\u0443\u043f\u0435\u043d \u0442\u043e\u043b\u044c\u043a\u043e \u043e\u0434\u0438\u043d \u0440\u0430\u0437 \u0434\u043b\u044f \u043d\u043e\u0432\u044b\u0445 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u0435\u0439."
  },
  {
    "key": "menu_instructions_response",
    "value": "\u0412\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u043e:"
  },
  {
    "key": "menu_instructions_buttons",
    "value": "[[{\"text\":\"\\ud83d\\udcf1 iOS\",\"response\":\"ios_guide_response\"},{\"text\":\"\\ud83e\\udd16 Android\",\"response\":\"android_guide_response\"}],[{\"text\":\"\\u2b50 \\u041a\\u0430\\u043a \\u043a\\u0443\\u043f\\u0438\\u0442\\u044c Stars\",\"response\":\"stars_buy_guide_response\"}]]"
  },
  {
    "key": "ios_guide_response",
    "value": "\ud83d\udcf1 iPhone (Streisand)\n\n\u0421\u0441\u044b\u043b\u043a\u0430 \u043d\u0430 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435: https://apps.apple.com/us/app/streisand/id6450534064\n\n1) \u0423\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0435 Streisand \u0438\u0437 App Store.\n2) \u0412 \u0431\u043e\u0442\u0435 \u043d\u0430\u0436\u043c\u0438\u0442\u0435 \u00ab\u041c\u043e\u044f \u043f\u043e\u0434\u043f\u0438\u0441\u043a\u0430\u00bb.\n3) \u0421\u043a\u043e\u043f\u0438\u0440\u0443\u0439\u0442\u0435 \u0441\u0441\u044b\u043b\u043a\u0443 \u043f\u043e\u0434\u043f\u0438\u0441\u043a\u0438.\n4) \u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 Streisand \u0438 \u043d\u0430\u0436\u043c\u0438\u0442\u0435 +.\n5) \u0412\u044b\u0431\u0435\u0440\u0438\u0442\u0435 Import from Clipboard.\n6) \u041d\u0430\u0436\u043c\u0438\u0442\u0435 Connect."
  },
  {
    "key": "android_guide_response",
    "value": "\ud83e\udd16 Android (Hiddify)\n\n\u0421\u0441\u044b\u043b\u043a\u0430 \u043d\u0430 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435: https://play.google.com/store/apps/details?id=app.hiddify.com\n\n1) \u0423\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0435 Hiddify \u0438\u0437 Google Play.\n2) \u0412 \u0431\u043e\u0442\u0435 \u043d\u0430\u0436\u043c\u0438\u0442\u0435 \u00ab\u041c\u043e\u044f \u043f\u043e\u0434\u043f\u0438\u0441\u043a\u0430\u00bb.\n3) \u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0441\u0441\u044b\u043b\u043a\u0443 \u043f\u043e\u0434\u043f\u0438\u0441\u043a\u0438 (\u0438\u043b\u0438 \u0438\u043c\u043f\u043e\u0440\u0442\u0438\u0440\u0443\u0439\u0442\u0435 \u0432\u0440\u0443\u0447\u043d\u0443\u044e).\n4) \u041d\u0430\u0436\u043c\u0438\u0442\u0435 Connect."
  },
  {
    "key": "trial_unavailable_message",
    "value": "\u041f\u0440\u043e\u0431\u043d\u044b\u0439 \u043f\u0435\u0440\u0438\u043e\u0434 \u0434\u043e\u0441\u0442\u0443\u043f\u0435\u043d \u0442\u043e\u043b\u044c\u043a\u043e \u043e\u0434\u0438\u043d \u0440\u0430\u0437 \u0434\u043b\u044f \u043d\u043e\u0432\u044b\u0445 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u0435\u0439."
  },
  {
    "key": "trial_activating_message",
    "value": "\u0410\u043a\u0442\u0438\u0432\u0438\u0440\u0443\u044e \u0432\u0430\u0448 \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u044b\u0439 \u043f\u0435\u0440\u0438\u043e\u0434 \u043d\u0430 7 \u0434\u043d\u0435\u0439..."
  },
  {
    "key": "menu_unknown_message",
    "value": "\u0418\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439\u0442\u0435 \u043a\u043d\u043e\u043f\u043a\u0438 \u043c\u0435\u043d\u044e \u043d\u0438\u0436\u0435."
  },
  {
    "key": "stars_only_notice",
    "value": "\u041e\u043f\u043b\u0430\u0442\u0430 \u0432 \u0431\u043e\u0442\u0435 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u0430 \u0442\u043e\u043b\u044c\u043a\u043e \u0447\u0435\u0440\u0435\u0437 Telegram Stars \u2b50\n\u0414\u043b\u044f iPhone \u0447\u0430\u0449\u0435 \u0432\u0441\u0435\u0433\u043e \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f \u043e\u043f\u043b\u0430\u0442\u0430 \u0447\u0435\u0440\u0435\u0437 \u043c\u043e\u0431\u0438\u043b\u044c\u043d\u044b\u0439 \u0431\u0430\u043b\u0430\u043d\u0441 \u041c\u0422\u0421."
  },
  {
    "key": "invoice_title",
    "value": "\u041e\u043f\u043b\u0430\u0442\u0430 VPN \u0447\u0435\u0440\u0435\u0437 Stars"
  },
  {
    "key": "invoice_description",
    "value": "\u041e\u043f\u043b\u0430\u0442\u0430 \u043f\u043e\u0434\u043f\u0438\u0441\u043a\u0438 \u0432\u044b\u043f\u043e\u043b\u043d\u044f\u0435\u0442\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e Telegram Stars. \u0414\u043b\u044f iPhone \u0447\u0430\u0449\u0435 \u0432\u0441\u0435\u0433\u043e \u2014 \u0447\u0435\u0440\u0435\u0437 \u043c\u043e\u0431\u0438\u043b\u044c\u043d\u044b\u0439 \u0431\u0430\u043b\u0430\u043d\u0441 \u041c\u0422\u0421."
  },
  {
    "key": "invoice_price_label",
    "value": "\u041e\u043f\u043b\u0430\u0442\u0430 \u0432 Stars"
  },
  {
    "key": "stars_buy_guide_response",
    "value": "\u2b50 \u041a\u0430\u043a \u043a\u0443\u043f\u0438\u0442\u044c Telegram Stars\n\n\u0421\u0435\u0439\u0447\u0430\u0441 \u043e\u043f\u043b\u0430\u0442\u0430 Stars \u0443 \u043d\u0430\u0441 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u0447\u0435\u0440\u0435\u0437 \u043c\u043e\u0431\u0438\u043b\u044c\u043d\u044b\u0439 \u0431\u0430\u043b\u0430\u043d\u0441 \u041c\u0422\u0421 (\u0420\u043e\u0441\u0441\u0438\u044f).\n\n\u0414\u043b\u044f iPhone (App Store):\n1) \u0423\u0431\u0435\u0434\u0438\u0442\u0435\u0441\u044c, \u0447\u0442\u043e \u0432 App Store \u0432\u044b\u0431\u0440\u0430\u043d \u0441\u043f\u043e\u0441\u043e\u0431 \u043e\u043f\u043b\u0430\u0442\u044b \u00ab\u041c\u043e\u0431\u0438\u043b\u044c\u043d\u044b\u0439 \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u00bb.\n2) \u041f\u0440\u0438\u0432\u044f\u0436\u0438\u0442\u0435 \u043d\u043e\u043c\u0435\u0440 \u041c\u0422\u0421 \u043a Apple ID \u043a\u0430\u043a \u0441\u043f\u043e\u0441\u043e\u0431 \u043e\u043f\u043b\u0430\u0442\u044b.\n3) \u041f\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435 \u0431\u0430\u043b\u0430\u043d\u0441 \u043d\u043e\u043c\u0435\u0440\u0430 \u041c\u0422\u0421.\n4) \u0412 Telegram \u043d\u0430\u0436\u043c\u0438\u0442\u0435 \u041a\u0443\u043f\u0438\u0442\u044c/\u041f\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u044c Stars \u0438 \u043f\u043e\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u0442\u0435 \u043e\u043f\u043b\u0430\u0442\u0443.\n\n\u0412\u0430\u0436\u043d\u043e: \u0435\u0441\u043b\u0438 \u043e\u043f\u043b\u0430\u0442\u0430 \u043d\u0435 \u043f\u0440\u043e\u0445\u043e\u0434\u0438\u0442, \u043f\u0440\u043e\u0432\u0435\u0440\u044c\u0442\u0435 \u0440\u0435\u0433\u0438\u043e\u043d Apple ID \u0438 \u0430\u043a\u0442\u0438\u0432\u043d\u044b\u0439 \u0441\u043f\u043e\u0441\u043e\u0431 \u043e\u043f\u043b\u0430\u0442\u044b."
  }
]
